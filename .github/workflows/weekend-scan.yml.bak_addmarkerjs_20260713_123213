name: Weekend Scan
# NOTE: workflow_run auto-trigger off Weekend Recon removed intentionally.
# Validation -> Recon -> Scan are being timed manually first; once durations
# are known, this will get an explicit cron offset instead of a reactive
# trigger, for consistency with weekday-scan and monthly-validation.
on:
  workflow_dispatch:

concurrency:
  group: weekend-scan-pipeline
  cancel-in-progress: false

jobs:
  prepare:
    if: github.event_name == 'workflow_dispatch' || github.event.workflow_run.conclusion != 'cancelled'
    runs-on: ubuntu-latest
    env:
      FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: true
    outputs:
      batches: ${{ steps.split.outputs.batches }}
      has_hosts: ${{ steps.split.outputs.has_hosts }}
      num_batches: ${{ steps.split.outputs.num_batches }}
      chunk_end: ${{ steps.split.outputs.chunk_end }}
      full_total: ${{ steps.split.outputs.full_total }}
    steps:
      - name: Checkout domains branch
        uses: actions/checkout@v4
        with:
          ref: domains
          fetch-depth: 1

      - name: Checkout status checker from main
        uses: actions/checkout@v4
        with:
          ref: main
          path: checker
          fetch-depth: 1

      - name: Build new_first list + calculate splits
        id: split
        run: |
          touch live_hosts.txt new_live_hosts.txt

          > combined.txt
          if [ -s new_live_hosts.txt ]; then
            cat new_live_hosts.txt >> combined.txt
          fi
          if [ -s live_hosts.txt ]; then
            if [ -s new_live_hosts.txt ]; then
              comm -23 <(sort live_hosts.txt) <(sort new_live_hosts.txt) >> combined.txt || true
            else
              cat live_hosts.txt >> combined.txt
            fi
          fi

          echo "Hosts before suspension filter: $(wc -l < combined.txt)"

          export HACKERONE_TOKEN="${{ secrets.HACKERONE_TOKEN }}"
          export INTIGRITI_TOKEN="${{ secrets.INTIGRITI_TOKEN }}"
          export MAPPING_CSV_PATH="checker/domain_program_map.csv"
          export EXCLUDED_OUTPUT_PATH="excluded_domains.txt"
          export HACKERONE_SCOPE_OUTPUT_PATH="hackerone_scope.txt"
          export INTIGRITI_SCOPE_OUTPUT_PATH="intigriti_scope.txt"
          export YESWEHACK_SCOPE_OUTPUT_PATH="yeswehack_scope.txt"
          export BUGCROWD_SCOPE_OUTPUT_PATH="bugcrowd_scope.txt"
          pip install tldextract --break-system-packages
          python3 checker/check_program_status.py

          if [ -s excluded_domains.txt ]; then
            > exclude_grep.txt
            while IFS= read -r d; do
              [ -z "$d" ] && continue
              escaped=$(echo "$d" | sed 's/\./\\./g')
              echo "\\.${escaped}\$|^${escaped}\$" >> exclude_grep.txt
            done < excluded_domains.txt
            grep -vEf exclude_grep.txt combined.txt > combined_filtered.txt || cp combined.txt combined_filtered.txt
            echo "Excluded $(( $(wc -l < combined.txt) - $(wc -l < combined_filtered.txt) )) hosts belonging to suspended/paused programs"
            mv combined_filtered.txt combined.txt
          fi

          echo "Hosts after suspension filter: $(wc -l < combined.txt)"

          full_total=$(wc -l < combined.txt)
          echo "Total hosts (full list): $full_total"

          if [ "$full_total" -eq 0 ]; then
            echo "has_hosts=false" >> $GITHUB_OUTPUT
            echo "batches=[]" >> $GITHUB_OUTPUT
            exit 0
          fi

          target_per_batch=25
          max_batches=256
          chunk_size=$(( target_per_batch * max_batches ))

          touch weekend_offset.txt
          offset=$(cat weekend_offset.txt 2>/dev/null)
          if [ -z "$offset" ] || [ "$offset" -gt "$full_total" ]; then
            offset=1
          fi

          chunk_end=$(( offset + chunk_size - 1 ))
          if [ "$chunk_end" -gt "$full_total" ]; then
            chunk_end=$full_total
          fi

          sed -n "${offset},${chunk_end}p" combined.txt > combined_chunk.txt
          mv combined_chunk.txt combined.txt

          total=$(wc -l < combined.txt)
          echo "Chunk: hosts $offset-$chunk_end of $full_total (this trigger: $total hosts)"

          echo "has_hosts=true" >> $GITHUB_OUTPUT
          num_batches=$(( (total + target_per_batch - 1) / target_per_batch ))
          if [ "$num_batches" -gt $max_batches ]; then num_batches=$max_batches; fi
          if [ "$num_batches" -lt 1 ]; then num_batches=1; fi
          echo "Batches: $num_batches (~$(( (total + num_batches - 1) / num_batches )) hosts each)"
          echo "num_batches=$num_batches" >> $GITHUB_OUTPUT
          echo "chunk_end=$chunk_end" >> $GITHUB_OUTPUT
          echo "full_total=$full_total" >> $GITHUB_OUTPUT

          touch weekend_progress.txt
          cp weekend_progress.txt done_batches.txt
          done_count=$(wc -l < done_batches.txt)
          if [ "$done_count" -ge "$num_batches" ]; then
            echo "Full cycle complete ($done_count/$num_batches) - resetting for new cycle"
            > weekend_progress.txt
            > done_batches.txt
          fi
          echo "Already completed this cycle: $(wc -l < done_batches.txt) of $num_batches batch(es)"

          batches=$(seq 1 $num_batches | grep -vFxf done_batches.txt | jq -R . | jq -sc .)
          echo "batches=$batches" >> $GITHUB_OUTPUT

      - name: Upload host list
        uses: actions/upload-artifact@v4
        with:
          name: weekend-hosts
          path: combined.txt
          retention-days: 7

  # ─── WEEKLY COMBINED: max-parallel 20 ─────────────────────────────
  weekend_combined:
    needs: prepare
    if: needs.prepare.outputs.has_hosts == 'true'
    runs-on: ubuntu-latest
    timeout-minutes: 350
    env:
      FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: true
    strategy:
      fail-fast: false
      max-parallel: 20
      matrix:
        batch: ${{ fromJson(needs.prepare.outputs.batches) }}
    steps:
      - name: Checkout domains branch
        uses: actions/checkout@v4
        with:
          ref: domains
          token: ${{ secrets.GITHUB_TOKEN }}
          fetch-depth: 0

      - name: Download host list
        uses: actions/download-artifact@v4
        with:
          name: weekend-hosts

      - name: Slice hosts for this batch
        run: |
          total=$(wc -l < combined.txt)
          num_batches=${{ needs.prepare.outputs.num_batches }}
          batch_num=${{ matrix.batch }}
          batch_size=$(( (total + num_batches - 1) / num_batches ))
          start=$(( (batch_num - 1) * batch_size + 1 ))
          end=$(( batch_num * batch_size ))
          sed -n "${start},${end}p" combined.txt > input.txt
          echo "Batch $batch_num/$num_batches: $(wc -l < input.txt) of $total hosts"

      - name: Pre-filter dead hosts (liveness check)
        run: |
          echo "Hosts before liveness filter: $(wc -l < input.txt)"
          cat input.txt | xargs -P 30 -I @@H@@ bash -c 'code=$(curl -s -o /dev/null -m 2 -w "%{http_code}" "@@H@@" 2>/dev/null || echo 000); if [ "$code" != "000" ]; then echo "@@H@@"; fi' > input_live.txt || true
          if [ -s input_live.txt ]; then mv input_live.txt input.txt; fi
          echo "Hosts after liveness filter: $(wc -l < input.txt)"

      - name: Get week number
        id: date
        run: echo "week=$(date +'%Y-%U')" >> $GITHUB_OUTPUT

      - name: Cache Go tools
        uses: actions/cache@v4
        id: cache-go
        with:
          path: ~/go/bin
          key: go-tools-${{ runner.os }}-v4

      - name: Install nuclei
        if: steps.cache-go.outputs.cache-hit != 'true'
        run: go install github.com/projectdiscovery/nuclei/v3/cmd/nuclei@latest

      - name: Ensure nuclei installed
        run: |
          export PATH=$PATH:$(go env GOPATH)/bin
          if ! command -v nuclei &>/dev/null; then
            go install github.com/projectdiscovery/nuclei/v3/cmd/nuclei@latest
          fi

      - name: Cache nuclei templates
        uses: actions/cache@v4
        id: cache-templates
        with:
          path: ~/.local/share/nuclei-templates
          key: nuclei-templates-${{ runner.os }}-${{ steps.date.outputs.week }}
          restore-keys: nuclei-templates-${{ runner.os }}-

      - name: Download nuclei templates
        if: steps.cache-templates.outputs.cache-hit != 'true'
        run: |
          mkdir -p $HOME/.local/share/nuclei-templates
          git clone --depth 1 https://github.com/projectdiscovery/nuclei-templates.git \
            $HOME/.local/share/nuclei-templates || true

      - name: Run nuclei
        run: |
          export PATH=$PATH:$(go env GOPATH)/bin
          TEMPLATES_DIR="$HOME/.local/share/nuclei-templates"
          touch results.txt

          if [ ! -s input.txt ]; then
            echo "No targets for this batch"
            exit 0
          fi

          TEMPLATE_PATHS="$TEMPLATES_DIR/http/misconfiguration,$TEMPLATES_DIR/http/exposed-panels,$TEMPLATES_DIR/http/exposures,$TEMPLATES_DIR/http/default-logins,$TEMPLATES_DIR/cloud"

          echo "[TIMING] Batch hosts: $(wc -l < input.txt)"
          echo "[TIMING] Scan start: $(date -u +'%Y-%m-%dT%H:%M:%SZ')"
          SCAN_START=$(date +%s)
          set +e

          timeout 20700 nuclei -l input.txt \
            -t "$TEMPLATE_PATHS" \
            -itags jwt,graphql,swagger,api-docs,openapi,git,env-file,default-login,jenkins,grafana,kibana,aws-s3,s3,springboot,actuator \
            -etags ssl,tls,http-missing-headers,tech,info,dns,helpers,passive,js \
            -severity low,medium,high,critical \
            -H "User-Agent: Mozilla/5.0 BugBounty/42 (YWH) Chemical Oxidizer CS_YWH/BB" \
            -H "X-Bug-Bounty: HackerOne-Chemical, HackerOne-Oxidizer" \
            -H "X-Bugcrowd-Research: Chemical, Oxidizer" \
            -H "X-Intigriti-Research: Chemical, Oxidizer" \
            -H "X-YesWeHack-Research: Chemical, Oxidizer" \
            -silent -retries 0 -timeout 3 \
            -bulk-size 5 -concurrency 5 \
            -rate-limit 5 -fhr -max-host-error 30 \
            -stats -si 30 \
            -no-color -o results.txt
          NUCLEI_EXIT=$?
          echo "$NUCLEI_EXIT" > nuclei_exit_code.txt
          if [ "$NUCLEI_EXIT" -eq 124 ]; then
            echo "::error::Nuclei timed out (exit 124) - failing step so batch is NOT marked done"
            exit 1
          fi

          SCAN_END=$(date +%s)
          echo "[TIMING] Scan end: $(date -u +'%Y-%m-%dT%H:%M:%SZ')"
          echo "[TIMING] Elapsed seconds: $(( SCAN_END - SCAN_START ))"
          if [ "$NUCLEI_EXIT" -eq 124 ]; then
            echo "[TIMING] WARNING: nuclei was killed by timeout - scan incomplete, batch will NOT be marked done"
          fi
          echo "Findings: $(wc -l < results.txt)"

      - name: Show results
        if: always()
        run: |
          count=$(wc -l < results.txt 2>/dev/null || echo 0)
          echo "Total findings: $count"
          if [ "$count" -gt "0" ]; then cat results.txt; else echo "No findings"; fi

      - name: Check for results
        id: check
        run: |
          if [ -s results.txt ]; then
            echo "found=true" >> $GITHUB_OUTPUT
            echo "count=$(wc -l < results.txt)" >> $GITHUB_OUTPUT
          else
            echo "found=false" >> $GITHUB_OUTPUT
            echo "count=0" >> $GITHUB_OUTPUT
          fi

      - name: Send email alert
        if: steps.check.outputs.found == 'true'
        uses: dawidd6/action-send-mail@v3
        with:
          server_address: smtp.gmail.com
          server_port: 465
          username: ${{ secrets.EMAIL_USER }}
          password: ${{ secrets.EMAIL_PASS }}
          subject: "[Weekend Combined ${{ matrix.batch }}] ${{ steps.check.outputs.count }} Finding(s)"
          body: file://results.txt
          to: ${{ secrets.EMAIL_TO }}
          from: BugBountyBot

      - name: Mark batch complete
        if: success()
        run: |
          echo "${{ matrix.batch }}" > batch_marker.txt

      - name: Upload batch completion marker
        if: success()
        uses: actions/upload-artifact@v4
        with:
          name: batch-marker-combined-${{ matrix.batch }}
          path: batch_marker.txt
          retention-days: 1

  finalize_progress:
    needs: [prepare, weekend_combined, weekend_custom_batched, weekend_js_secrets_batched]
    if: always() && needs.weekend_combined.result != 'cancelled'
    runs-on: ubuntu-latest
    steps:
      - name: Checkout domains branch
        uses: actions/checkout@v4
        with:
          ref: domains
          token: ${{ secrets.GITHUB_TOKEN }}
          fetch-depth: 0

      - name: Download all batch markers
        uses: actions/download-artifact@v4
        with:
          path: batch_markers
          pattern: batch-marker-*

      - name: Merge markers into weekend_progress.txt
        run: |
          git config --global user.email "bugbountybot@github.com"
          git config --global user.name "BugBountyBot"
          touch weekend_progress.txt weekend_offset.txt
          find batch_markers -name "batch_marker.txt" -exec cat {} \; >> weekend_progress.txt
          sort -n -u weekend_progress.txt -o weekend_progress.txt
          done_count=$(wc -l < weekend_progress.txt)
          echo "Batches marked complete this run: $done_count"

          NUM_BATCHES="${{ needs.prepare.outputs.num_batches }}"
          CHUNK_END="${{ needs.prepare.outputs.chunk_end }}"
          FULL_TOTAL="${{ needs.prepare.outputs.full_total }}"

          if [ -n "$NUM_BATCHES" ] && [ "$done_count" -ge "$NUM_BATCHES" ]; then
            NEW_OFFSET=$(( CHUNK_END + 1 ))
            if [ "$NEW_OFFSET" -gt "$FULL_TOTAL" ]; then
              NEW_OFFSET=1
            fi
            echo "Chunk complete ($done_count/$NUM_BATCHES) - advancing offset to $NEW_OFFSET"
            echo "$NEW_OFFSET" > weekend_offset.txt
            > weekend_progress.txt
          else
            echo "Chunk not yet complete ($done_count/$NUM_BATCHES) - offset unchanged, resuming same chunk next trigger"
          fi

          git add weekend_progress.txt weekend_offset.txt
          git diff --staged --quiet || git commit -m "Weekend scan progress update $(date +'%Y-%m-%d')"
          git push origin domains || (git pull --rebase origin domains && git push origin domains) || echo "::warning::Push failed for weekend_progress.txt"


  # ─── JS SECRETS ────────────────────────────────────────────────
  weekend_js_secrets_batched:
    needs: [prepare, weekend_custom_batched]
    if: always() && !cancelled() && needs.weekend_custom_batched.result != 'failure' && needs.prepare.outputs.has_hosts == 'true'
    runs-on: ubuntu-latest
    timeout-minutes: 350
    env:
      FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: true
    strategy:
      fail-fast: false
      max-parallel: 20
      matrix:
        batch: ${{ fromJson(needs.prepare.outputs.batches) }}
    steps:
      - name: Checkout domains branch
        uses: actions/checkout@v4
        with:
          ref: domains
          token: ${{ secrets.GITHUB_TOKEN }}
          fetch-depth: 0

      - name: Download host list
        uses: actions/download-artifact@v4
        with:
          name: weekend-hosts

      - name: Slice hosts for this batch
        run: |
          total=$(wc -l < combined.txt)
          num_batches=${{ needs.prepare.outputs.num_batches }}
          batch_num=${{ matrix.batch }}
          batch_size=$(( (total + num_batches - 1) / num_batches ))
          start=$(( (batch_num - 1) * batch_size + 1 ))
          end=$(( batch_num * batch_size ))
          sed -n "${start},${end}p" combined.txt > input.txt
          echo "Batch $batch_num/$num_batches: $(wc -l < input.txt) of $total hosts"

      - name: Pre-filter dead hosts (liveness check)
        run: |
          echo "Hosts before liveness filter: $(wc -l < input.txt)"
          cat input.txt | xargs -P 30 -I @@H@@ bash -c 'code=$(curl -s -o /dev/null -m 2 -w "%{http_code}" "@@H@@" 2>/dev/null || echo 000); if [ "$code" != "000" ]; then echo "@@H@@"; fi' > input_live.txt || true
          if [ -s input_live.txt ]; then mv input_live.txt input.txt; fi
          echo "Hosts after liveness filter: $(wc -l < input.txt)"

      - name: Get week number
        id: date
        run: echo "week=$(date +'%Y-%U')" >> $GITHUB_OUTPUT

      - name: Cache Go tools
        uses: actions/cache@v4
        id: cache-go
        with:
          path: ~/go/bin
          key: go-tools-${{ runner.os }}-v4

      - name: Install nuclei and katana
        if: steps.cache-go.outputs.cache-hit != 'true'
        run: |
          go install github.com/projectdiscovery/nuclei/v3/cmd/nuclei@latest
          go install github.com/projectdiscovery/katana/cmd/katana@latest

      - name: Ensure nuclei and katana installed
        run: |
          export PATH=$PATH:$(go env GOPATH)/bin
          if ! command -v nuclei &>/dev/null; then
            go install github.com/projectdiscovery/nuclei/v3/cmd/nuclei@latest
          fi
          if ! command -v katana &>/dev/null; then
            go install github.com/projectdiscovery/katana/cmd/katana@latest
          fi

      - name: Cache nuclei templates
        uses: actions/cache@v4
        id: cache-templates
        with:
          path: ~/.local/share/nuclei-templates
          key: nuclei-templates-${{ runner.os }}-${{ steps.date.outputs.week }}
          restore-keys: nuclei-templates-${{ runner.os }}-

      - name: Download nuclei templates
        if: steps.cache-templates.outputs.cache-hit != 'true'
        run: |
          mkdir -p $HOME/.local/share/nuclei-templates
          git clone --depth 1 https://github.com/projectdiscovery/nuclei-templates.git \
            $HOME/.local/share/nuclei-templates || true

      - name: Run katana
        run: |
          export PATH=$PATH:$(go env GOPATH)/bin
          cp input.txt katana_input.txt
          timeout 3600 katana -list katana_input.txt \
            -silent \
            -js-crawl \
            -depth 1 \
            -timeout 3 \
            -rl 5 \
            -concurrency 5 \
            -max-response-size 2000000 \
            -H "User-Agent: Mozilla/5.0 BugBounty/42 (YWH) Chemical Oxidizer CS_YWH/BB" \
            -H "X-Bug-Bounty: HackerOne-Chemical, HackerOne-Oxidizer" \
            -H "X-Bugcrowd-Research: Chemical, Oxidizer" \
            -H "X-Intigriti-Research: Chemical, Oxidizer" \
            -H "X-YesWeHack-Research: Chemical, Oxidizer" \
            -o urls.txt || true
          if [ -f urls.txt ]; then
            sort -u urls.txt | head -1000 > urls_capped.txt
            mv urls_capped.txt urls.txt
          else
            touch urls.txt
          fi
          echo "URLs found: $(wc -l < urls.txt 2>/dev/null || echo 0)"

      - name: Run nuclei (JS secrets)
        run: |
          export PATH=$PATH:$(go env GOPATH)/bin
          TEMPLATES_DIR="$HOME/.local/share/nuclei-templates"
          touch results.txt

          if [ -s urls.txt ]; then
            cat input.txt urls.txt | sort -u > combined_input.txt
            INPUT_FILE="combined_input.txt"
          else
            INPUT_FILE="input.txt"
          fi

          if [ ! -s "$INPUT_FILE" ]; then
            echo "No targets for this batch"
            exit 0
          fi

          echo "[TIMING] Batch hosts: $(wc -l < input.txt)"
          echo "[TIMING] Scan start: $(date -u +'%Y-%m-%dT%H:%M:%SZ')"
          SCAN_START=$(date +%s)
          set +e

          timeout 20700 nuclei -l "$INPUT_FILE" \
            -t "$TEMPLATES_DIR/http/exposures" \
            -itags token,secret,api-key,generic-tokens \
            -etags ssl,tls,http-missing-headers,tech,info,dns,helpers,passive \
            -severity low,medium,high,critical \
            -H "User-Agent: Mozilla/5.0 BugBounty/42 (YWH) Chemical Oxidizer CS_YWH/BB" \
            -H "X-Bug-Bounty: HackerOne-Chemical, HackerOne-Oxidizer" \
            -H "X-Bugcrowd-Research: Chemical, Oxidizer" \
            -H "X-Intigriti-Research: Chemical, Oxidizer" \
            -H "X-YesWeHack-Research: Chemical, Oxidizer" \
            -silent -retries 0 -timeout 3 \
            -bulk-size 5 -concurrency 5 \
            -rate-limit 5 -fhr -max-host-error 30 \
            -stats -si 30 \
            -no-color -o results.txt
          NUCLEI_EXIT=$?
          echo "$NUCLEI_EXIT" > nuclei_exit_code.txt
          if [ "$NUCLEI_EXIT" -eq 124 ]; then
            echo "::error::Nuclei timed out (exit 124) - failing step so batch is NOT marked done"
            exit 1
          fi

          SCAN_END=$(date +%s)
          echo "[TIMING] Scan end: $(date -u +'%Y-%m-%dT%H:%M:%SZ')"
          echo "[TIMING] Elapsed seconds: $(( SCAN_END - SCAN_START ))"
          echo "Findings: $(wc -l < results.txt)"

      - name: Show results
        if: always()
        run: |
          count=$(wc -l < results.txt 2>/dev/null || echo 0)
          echo "Total findings: $count"
          if [ "$count" -gt "0" ]; then cat results.txt; else echo "No findings"; fi

      - name: Check for results
        id: check
        run: |
          if [ -s results.txt ]; then
            echo "found=true" >> $GITHUB_OUTPUT
            echo "count=$(wc -l < results.txt)" >> $GITHUB_OUTPUT
          else
            echo "found=false" >> $GITHUB_OUTPUT
            echo "count=0" >> $GITHUB_OUTPUT
          fi

      - name: Send email alert
        if: steps.check.outputs.found == 'true'
        uses: dawidd6/action-send-mail@v3
        with:
          server_address: smtp.gmail.com
          server_port: 465
          username: ${{ secrets.EMAIL_USER }}
          password: ${{ secrets.EMAIL_PASS }}
          subject: "[Weekend JS Secrets ${{ matrix.batch }}] ${{ steps.check.outputs.count }} Finding(s)"
          body: file://results.txt
          to: ${{ secrets.EMAIL_TO }}
          from: BugBountyBot

  # ─── CUSTOM TEMPLATES ──────────────────────────────────────────
  weekend_custom_batched:
    needs: [prepare, weekend_combined]
    if: always() && !cancelled() && needs.weekend_combined.result != 'failure' && needs.prepare.outputs.has_hosts == 'true'
    runs-on: ubuntu-latest
    timeout-minutes: 350
    env:
      FORCE_JAVASCRIPT_ACTIONS_TO_NODE24: true
    strategy:
      fail-fast: false
      max-parallel: 20
      matrix:
        batch: ${{ fromJson(needs.prepare.outputs.batches) }}
    steps:
      - name: Checkout main branch (custom-templates live here)
        uses: actions/checkout@v4
        with:
          ref: main
          fetch-depth: 1

      - name: Checkout domains branch host list
        uses: actions/checkout@v4
        with:
          ref: domains
          token: ${{ secrets.GITHUB_TOKEN }}
          fetch-depth: 0
          path: domains-branch

      - name: Download host list
        uses: actions/download-artifact@v4
        with:
          name: weekend-hosts

      - name: Slice hosts for this batch
        run: |
          total=$(wc -l < combined.txt)
          num_batches=${{ needs.prepare.outputs.num_batches }}
          batch_num=${{ matrix.batch }}
          batch_size=$(( (total + num_batches - 1) / num_batches ))
          start=$(( (batch_num - 1) * batch_size + 1 ))
          end=$(( batch_num * batch_size ))
          sed -n "${start},${end}p" combined.txt > input.txt
          echo "Batch $batch_num/$num_batches: $(wc -l < input.txt) of $total hosts"

      - name: Pre-filter dead hosts (liveness check)
        run: |
          echo "Hosts before liveness filter: $(wc -l < input.txt)"
          cat input.txt | xargs -P 30 -I @@H@@ bash -c 'code=$(curl -s -o /dev/null -m 2 -w "%{http_code}" "@@H@@" 2>/dev/null || echo 000); if [ "$code" != "000" ]; then echo "@@H@@"; fi' > input_live.txt || true
          if [ -s input_live.txt ]; then mv input_live.txt input.txt; fi
          echo "Hosts after liveness filter: $(wc -l < input.txt)"

      - name: Get week number
        id: date
        run: echo "week=$(date +'%Y-%U')" >> $GITHUB_OUTPUT

      - name: Cache Go tools
        uses: actions/cache@v4
        id: cache-go
        with:
          path: ~/go/bin
          key: go-tools-${{ runner.os }}-v4

      - name: Install nuclei
        if: steps.cache-go.outputs.cache-hit != 'true'
        run: go install github.com/projectdiscovery/nuclei/v3/cmd/nuclei@latest

      - name: Ensure nuclei installed
        run: |
          export PATH=$PATH:$(go env GOPATH)/bin
          if ! command -v nuclei &>/dev/null; then
            go install github.com/projectdiscovery/nuclei/v3/cmd/nuclei@latest
          fi

      - name: Run nuclei (custom templates only)
        run: |
          export PATH=$PATH:$(go env GOPATH)/bin
          touch results.txt

          if [ ! -s input.txt ]; then
            echo "No targets for this batch"
            exit 0
          fi

          if [ ! -d custom-templates ] || [ -z "$(ls -A custom-templates)" ]; then
            echo "No custom templates found, skipping"
            exit 0
          fi

          echo "[TIMING] Batch hosts: $(wc -l < input.txt)"
          echo "[TIMING] Scan start: $(date -u +'%Y-%m-%dT%H:%M:%SZ')"
          SCAN_START=$(date +%s)
          set +e

          timeout 20700 nuclei -l input.txt \
            -t custom-templates \
            -severity low,medium,high,critical \
            -H "User-Agent: Mozilla/5.0 BugBounty/42 (YWH) Chemical Oxidizer CS_YWH/BB" \
            -H "X-Bug-Bounty: HackerOne-Chemical, HackerOne-Oxidizer" \
            -H "X-Bugcrowd-Research: Chemical, Oxidizer" \
            -H "X-Intigriti-Research: Chemical, Oxidizer" \
            -H "X-YesWeHack-Research: Chemical, Oxidizer" \
            -silent -retries 0 -timeout 3 \
            -bulk-size 5 -concurrency 5 \
            -rate-limit 5 -fhr -max-host-error 30 \
            -stats -si 30 \
            -no-color -o results.txt
          NUCLEI_EXIT=$?
          echo "$NUCLEI_EXIT" > nuclei_exit_code.txt
          if [ "$NUCLEI_EXIT" -eq 124 ]; then
            echo "::error::Nuclei timed out (exit 124) - failing step so batch is NOT marked done"
            exit 1
          fi

          SCAN_END=$(date +%s)
          echo "[TIMING] Scan end: $(date -u +'%Y-%m-%dT%H:%M:%SZ')"
          echo "[TIMING] Elapsed seconds: $(( SCAN_END - SCAN_START ))"
          echo "Findings: $(wc -l < results.txt)"

      - name: Show results
        if: always()
        run: |
          count=$(wc -l < results.txt 2>/dev/null || echo 0)
          echo "Total findings: $count"
          if [ "$count" -gt "0" ]; then cat results.txt; else echo "No findings"; fi

      - name: Check for results
        id: check
        run: |
          if [ -s results.txt ]; then
            echo "found=true" >> $GITHUB_OUTPUT
            echo "count=$(wc -l < results.txt)" >> $GITHUB_OUTPUT
          else
            echo "found=false" >> $GITHUB_OUTPUT
            echo "count=0" >> $GITHUB_OUTPUT
          fi

      - name: Send email alert
        if: steps.check.outputs.found == 'true'
        uses: dawidd6/action-send-mail@v3
        with:
          server_address: smtp.gmail.com
          server_port: 465
          username: ${{ secrets.EMAIL_USER }}
          password: ${{ secrets.EMAIL_PASS }}
          subject: "[Weekend Custom ${{ matrix.batch }}] ${{ steps.check.outputs.count }} Finding(s)"
          body: file://results.txt
          to: ${{ secrets.EMAIL_TO }}
          from: BugBountyBot

      - name: Mark batch complete
        if: success()
        run: |
          echo "${{ matrix.batch }}" > batch_marker.txt

      - name: Upload batch completion marker
        if: success()
        uses: actions/upload-artifact@v4
        with:
          name: batch-marker-custom-${{ matrix.batch }}
          path: batch_marker.txt
          retention-days: 1
